<div class="form-card wide">
  <%= form_with(url: games_path, method: :post) do |form| %>
    <% if game.errors.any? %>
      <div class="error-box">
        <strong><%= pluralize(game.errors.count, "error") %>:</strong>
        <ul>
          <% game.errors.each do |error| %>
            <li><%= error.full_message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="game-vs-grid">
      <div>
        <div class="form-group">
          <label>Player 1</label>
          <%= select_tag "game[player1_id]",
              options_from_collection_for_select(players, :id, :name),
              prompt: "Select player" %>
        </div>
        <div class="form-group">
          <label>Score</label>
          <%= number_field_tag "game[player1_score]", nil, min: 0, class: "score-input" %>
        </div>
      </div>

      <div class="vs-badge">VS</div>

      <div>
        <div class="form-group">
          <label>Player 2</label>
          <%= select_tag "game[player2_id]",
              options_from_collection_for_select(players, :id, :name),
              prompt: "Select player" %>
        </div>
        <div class="form-group">
          <label>Score</label>
          <%= number_field_tag "game[player2_score]", nil, min: 0, class: "score-input" %>
        </div>
      </div>
    </div>

    <%= form.submit "Log Result", class: "btn btn-primary", style: "width: 100%; justify-content: center; padding: 0.7rem;" %>
  <% end %>
</div>
